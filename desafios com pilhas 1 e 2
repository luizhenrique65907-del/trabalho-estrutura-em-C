EXERCÍCIO 2
#include <stdio.h>
#include <stdlib.h>

// nó da pilha
struct No {
    char dado;
    struct No *prox;
};

// empilha caractere
void push(struct No **topo, char c) {
    struct No *novo = malloc(sizeof(struct No));
    if (novo == NULL) return;

    novo->dado = c;
    novo->prox = *topo;
    *topo = novo;
}

// desempilha
char pop(struct No **topo) {
    if (*topo == NULL) return '\0';

    struct No *temp = *topo;
    char c = temp->dado;

    *topo = temp->prox;
    free(temp);

    return c;
}

// verifica se vazia
int isEmpty(struct No *topo) {
    return topo == NULL;
}

int main() {
    char str[100];
    struct No *pilha = NULL;

    scanf(" %[^\n]", str);

    for (int i = 0; str[i] != '\0'; i++) {
        push(&pilha, str[i]);
    }

    while (!isEmpty(pilha)) {
        printf("%c", pop(&pilha));
    }

    printf("\n");
    return 0;
}
