struct Aluno10 {
    char nome[50];
    float nota;
};

struct Aluno10* maiorNota(struct Aluno10 *a, int n){
    struct Aluno10 *m = a;

    for(int i = 1; i < n; i++){
        if((a+i)->nota > m->nota)
            m = a+i;
    }

    return m;
}

void ex10() {
    int n;
    scanf("%d", &n);

    struct Aluno10 *a = malloc(n * sizeof(struct Aluno10));

    for(int i = 0; i < n; i++){
        scanf(" %[^\n]", (a+i)->nome);
        scanf("%f", &(a+i)->nota);
    }

    struct Aluno10 *top = maiorNota(a, n);

    printf("Maior nota: %s %.2f\n", top->nome, top->nota);

    free(a);
}
