void ex4() {
    int m[3][3], identidade[3][3], r[3][3];

    for(int i=0;i<3;i++)
        for(int j=0;j<3;j++)
            scanf("%d", &m[i][j]);

    for(int i=0;i<3;i++)
        for(int j=0;j<3;j++)
            identidade[i][j] = (i==j)?1:0;

    printf("Matriz identidade:\n");
    for(int i=0;i<3;i++){
        for(int j=0;j<3;j++)
            printf("%d ", identidade[i][j]);
        printf("\n");
    }

    for(int i=0;i<3;i++){
        for(int j=0;j<3;j++){
            r[i][j]=0;
            for(int k=0;k<3;k++)
                r[i][j]+=m[i][k]*identidade[k][j];
        }
    }

    printf("Resultado:\n");
    for(int i=0;i<3;i++){
        for(int j=0;j<3;j++)
            printf("%d ", r[i][j]);
        printf("\n");
    }
}

