void ex5() {
    int v[3], m[3][3], r[3];

    for (int i = 0; i < 3; i++)
        scanf("%d", &v[i]);

    for (int i = 0; i < 3; i++)
        for (int j = 0; j < 3; j++)
            scanf("%d", &m[i][j]);

    for (int j = 0; j < 3; j++) {
        r[j] = 0;
        for (int i = 0; i < 3; i++)
            r[j] += v[i] * m[i][j];
    }

    printf("Resultado:\n");
    for (int i = 0; i < 3; i++)
        printf("%d ", r[i]);

    printf("\n");
}

