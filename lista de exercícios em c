int ordenar(int *a, int *b, int *c){
    int t;

    if(*a > *b){ t = *a; *a = *b; *b = t; }
    if(*a > *c){ t = *a; *a = *c; *c = t; }
    if(*b > *c){ t = *b; *b = *c; *c = t; }

    return (*a == *b && *b == *c);
}

void ex9() {
    int a, b, c;

    scanf("%d %d %d", &a, &b, &c);

    int iguais = ordenar(&a, &b, &c);

    printf("%d %d %d\n", a, b, c);
    printf("Iguais? %d\n", iguais);
}

