EXERCÍCIO 1
#include <stdio.h>
#include <stdlib.h>

// cliente da fila
struct Cliente {
    int id;
    int tempoAtendimento;
};

// nó da fila
struct No {
    struct Cliente c;
    struct No *prox;
};

// estrutura da fila
struct Fila {
    struct No *inicio;
    struct No *fim;
};

// adiciona na fila
void enqueue(struct Fila *f, struct Cliente c) {
    struct No *novo = malloc(sizeof(struct No));
    novo->c = c;
    novo->prox = NULL;

    if (f->fim == NULL) {
        f->inicio = novo;
        f->fim = novo;
    } else {
        f->fim->prox = novo;
        f->fim = novo;
    }
}

// remove da fila
struct Cliente dequeue(struct Fila *f) {
    struct Cliente c = {0,0};

    if (f->inicio == NULL) return c;

    struct No *temp = f->inicio;
    c = temp->c;

    f->inicio = temp->prox;
    if (f->inicio == NULL)
        f->fim = NULL;

    free(temp);
    return c;
}

// verifica vazia
int isEmpty(struct Fila *f) {
    return f->inicio == NULL;
}

int main() {
    struct Fila fila;
    fila.inicio = NULL;
    fila.fim = NULL;

    int n;
    scanf("%d", &n);

    // lê clientes
    for (int i = 0; i < n; i++) {
        struct Cliente c;
        scanf("%d %d", &c.id, &c.tempoAtendimento);
        enqueue(&fila, c);
    }

    int tempoEspera = 0;

    // simula atendimento
    while (!isEmpty(&fila)) {
        struct Cliente c = dequeue(&fila);

        printf("Cliente %d - Espera: %d min\n", c.id, tempoEspera);

        tempoEspera += c.tempoAtendimento;
    }

    return 0;
}

